# ============================================================
# STORE RQTA — Variables de entorno
# ============================================================
# Copiá este archivo a .env.local y completá los valores.
# En Vercel: Project → Settings → Environment Variables
# ============================================================

# ── Base de datos PostgreSQL (Supabase) ─────────────────────
#
# Obtener en: Supabase → Project → Settings → Database → Connection string
# Usar "Transaction pooler" (puerto 6543) para entornos serverless (Vercel)
#
# Formato: postgresql://postgres.PROYECTO:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
#
DATABASE_URL=postgresql://postgres.tu_proyecto:tu_password@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# ── Admin ────────────────────────────────────────────────────
#
# Contraseña para acceder a /admin
# Cambiar en producción por una contraseña segura (mínimo 12 chars)
#
ADMIN_PASSWORD=cambiar_esto_en_produccion

# ── App (opcionales) ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://tu-dominio.vercel.app
